FROM python:3.12-slim

WORKDIR /app

# 의존성 레이어 캐싱 — 소스 변경 시 pip install 재실행 방지
COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

COPY app/ ./app/
COPY pkl/ ./pkl/

# serviceAccountKey.json 은 docker-compose volume 으로 주입 (이미지에 포함 금지)

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
