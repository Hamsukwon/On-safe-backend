# docker-compose 실행 전 이 파일을 .env 로 복사 후 값 입력
# cp .env.example .env

# ── 필수 ─────────────────────────────────────────────────────────────────────
# JWT 서명 키 (32자 이상 랜덤 문자열, python-ai / kotlin-api 공통)
JWT_SECRET=your-jwt-secret-key-min-32-chars-change-this

# Firebase 서비스 계정 키 경로 (컨테이너 내부 경로 — 변경 불필요)
FIREBASE_CREDENTIALS=/app/secrets/serviceAccountKey.json

# ── 이메일 (비밀번호 재설정 인증코드 발송) ────────────────────────────────────
# Gmail 사용 시: Google 계정 → 앱 비밀번호 발급 후 MAIL_PASSWORD에 입력
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
