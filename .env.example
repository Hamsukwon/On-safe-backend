# docker-compose 실행 전 이 파일을 .env 로 복사 후 값 입력
# cp .env.example .env

# ── 필수 ─────────────────────────────────────────────────────────────────────
# JWT 서명 키 (32자 이상 랜덤 문자열, python-ai / kotlin-api 공통)
JWT_SECRET=your-jwt-secret-key-min-32-chars-change-this

# 민감정보 AES-256-GCM 암호화 키 (base64 인코딩된 32바이트)
# 생성 예: openssl rand -base64 32
ENCRYPTION_AES_KEY=

# Firebase 서비스 계정 키 경로 (컨테이너 내부 경로 — 변경 불필요)
FIREBASE_CREDENTIALS=/app/secrets/serviceAccountKey.json

# Firebase Storage 버킷 이름 (serviceAccountKey.json의 project_id + ".appspot.com")
# Firebase Console → Storage → 버킷 이름 확인 후 입력
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ── 이메일 (AWS SES — 비밀번호 재설정 · 이메일 인증코드 발송) ──────────────────
# SES 콘솔에서 인증된 발신자 이메일 주소 입력
SES_FROM_EMAIL=no-reply@yourdomain.com
# SES 리전 (기본값: ap-northeast-2)
AWS_REGION=ap-northeast-2
# IAM 액세스 키 (로컬/Docker 환경용 — EC2/ECS는 IAM Role로 대체)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
