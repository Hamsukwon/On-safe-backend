# docker-compose 실행 전 이 파일을 .env 로 복사 후 값 입력
# cp .env.example .env

# ── 필수 ─────────────────────────────────────────────────────────────────────
# JWT 서명 키 (32자 이상 랜덤 문자열, python-ai / kotlin-api 공통)
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long

# Firebase 서비스 계정 키 경로 (컨테이너 내부 경로 — 변경 불필요)
FIREBASE_CREDENTIALS=/app/secrets/serviceAccountKey.json
